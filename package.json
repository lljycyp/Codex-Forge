  "description": "Windows profile and multi-instance manager for the ChatGPT desktop app.",
  "author": "ChatGPT Forge",
  "private": true,
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "node scripts/build.js",
